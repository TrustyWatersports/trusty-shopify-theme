<div style="background: var(--gray-light); border-radius: 16px; padding: 40px; margin: 40px 0;">
  <div style="text-align: center; margin-bottom: 30px;">
    <div style="font-size: 36px; margin-bottom: 12px;">&#x1F4C5;</div>
    <h2 style="font-size: 28px; color: var(--ocean-deep); margin-bottom: 8px;">{{ section.settings.heading }}</h2>
    <p style="color: var(--gray-medium); font-size: 16px; max-width: 500px; margin: 0 auto;">{{ section.settings.subtext }}</p>
  </div>

  <!-- Step indicators -->
  <div style="display: flex; justify-content: center; gap: 0; margin-bottom: 35px; flex-wrap: wrap;">
    <div style="display: flex; align-items: center; gap: 10px;">
      <div style="background: var(--rigging-accent); color: white; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; flex-shrink: 0;">1</div>
      <span style="font-weight: 700; color: var(--ocean-deep); font-size: 15px;">Pick your date</span>
    </div>
    <div style="width: 40px; height: 2px; background: var(--gray-medium); margin: 0 10px; align-self: center;"></div>
    <div style="display: flex; align-items: center; gap: 10px;">
      <div style="background: var(--gray-medium); color: white; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; flex-shrink: 0;">2</div>
      <span style="font-weight: 700; color: var(--gray-medium); font-size: 15px;">Complete payment</span>
    </div>
    <div style="width: 40px; height: 2px; background: var(--gray-medium); margin: 0 10px; align-self: center;"></div>
    <div style="display: flex; align-items: center; gap: 10px;">
      <div style="background: var(--gray-medium); color: white; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; flex-shrink: 0;">3</div>
      <span style="font-weight: 700; color: var(--ocean-deep); font-size: 15px;">Show up &amp; enjoy</span>
    </div>
  </div>

  <!-- TidyCal inline embed -->
  {% assign booking_path = product.metafields.custom.calendly_url | default: section.settings.calendly_url %}
  <div class="tidycal-embed"
       data-path="{{ booking_path }}"
       style="min-width: 320px; border-radius: 12px; overflow: hidden;">
  </div>
  <script src="https://asset-tidycal.b-cdn.net/js/embed.js" async></script>

  <!-- Unlock checkout after TidyCal booking -->
  <script>
    window.addEventListener('message', function(e) {
      if (e.data && e.data.type === 'tidycal:booking_confirmed') {
        var btn = document.getElementById('add-to-cart-button') || document.querySelector('[name="add"]');
        if (btn) {
          btn.disabled = false;
          btn.removeAttribute('disabled');
          btn.style.opacity = '1';
          btn.style.pointerEvents = 'auto';
          btn.textContent = 'Proceed to Checkout';
          btn.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
    });
  </script>

  <p style="text-align: center; margin-top: 16px; font-size: 13px; color: var(--gray-medium);">
    After selecting your time, you'll be redirected to complete payment. &nbsp;|&nbsp; Questions? Call <a href="tel:252-499-9911" style="color: var(--ocean-medium);">(252) 499-9911</a>
  </p>
</div>

{% schema %}
{
  "name": "Calendly Booking",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Check Availability & Book Your Date"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Pick your date first — you'll complete payment after selecting your time slot."
    },
    {
      "type": "text",
      "id": "calendly_url",
      "label": "TidyCal Booking Path",
      "info": "The data-path value for this booking type, e.g. trustywatersports/single-kayak-rental-half-day20260309131357"
    }
  ],
  "presets": [{ "name": "Calendly Booking" }]
}
{% endschema %}
