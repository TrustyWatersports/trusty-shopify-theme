{% schema %}
{
  "name": "Used Boats Hero",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title",
      "default": "Used Boats & Consignment"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Subtitle",
      "default": "Quality pre-owned kayaks and sailboats"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background Photo (optional)"
    },
    {
      "type": "range",
      "id": "image_opacity",
      "label": "Photo Visibility",
      "info": "Higher = more photo visible",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 70,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Color Overlay Strength",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 55,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#0A4B78"
    }
  ]
}
{% endschema %}

<section style="position: relative; padding: 80px 20px; text-align: center; color: white; overflow: hidden;">
  {% if section.settings.hero_image %}
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-image: url('{{ section.settings.hero_image | img_url: '2048x' }}'); background-size: cover; background-position: center; opacity: {{ section.settings.image_opacity | divided_by: 100.0 }}; z-index: 0;"></div>
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: {{ section.settings.background_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; z-index: 1;"></div>
  {% else %}
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: {{ section.settings.background_color }}; z-index: 0;"></div>
  {% endif %}
  <div style="max-width: 900px; margin: 0 auto; position: relative; z-index: 2;">
    <h1 style="font-size: 3rem; margin-bottom: 1rem;">{{ section.settings.hero_title }}</h1>
    <p style="font-size: 1.3rem; opacity: 0.95;">{{ section.settings.hero_subtitle }}</p>
  </div>
</section>
