{% comment %} trusty-why-trusty.liquid — proof/stats layout, all content from schema {% endcomment %}
<section style="padding: 72px 20px; background: #faf9f7;">
  <div style="max-width: 1100px; margin: 0 auto;">

    <div style="text-align: center; margin-bottom: 56px;">
      <h2 style="font-size: 36px; font-weight: 800; color: #0a3d5c; margin: 0 0 12px;">{{ section.settings.heading }}</h2>
      <p style="font-size: 17px; color: #666; max-width: 520px; margin: 0 auto; line-height: 1.6;">{{ section.settings.subtitle }}</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1px; background: #ddd8d0; border-radius: 16px; overflow: hidden; margin-bottom: 56px; box-shadow: 0 4px 24px rgba(0,0,0,0.06);">
      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }}
          style="background: #fff; padding: 32px 24px; display: flex; flex-direction: column; align-items: flex-start; gap: 10px; transition: background 0.2s;" onmouseover="this.style.background='#f7fdfb'" onmouseout="this.style.background='#fff'">
          <!-- SVG accent line instead of emoji -->
          <div style="width: 32px; height: 4px; border-radius: 2px; background: #1d9e75;"></div>
          <h3 style="font-size: 18px; font-weight: 700; color: #0a3d5c; margin: 0; line-height: 1.2;">{{ block.settings.title }}</h3>
          <p style="font-size: 14px; color: #666; line-height: 1.65; margin: 0;">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>

    <!-- Stat row -->
    <div style="display: flex; gap: 0; background: #0a3d5c; border-radius: 16px; overflow: hidden; flex-wrap: wrap;">
      <div style="flex: 1; min-width: 150px; padding: 28px 24px; text-align: center; border-right: 1px solid rgba(255,255,255,0.1);">
        <div style="font-size: 36px; font-weight: 800; color: #1d9e75; line-height: 1;">500+</div>
        <div style="font-size: 13px; color: rgba(255,255,255,0.7); margin-top: 6px; font-weight: 500;">Rigs Built</div>
      </div>
      <div style="flex: 1; min-width: 150px; padding: 28px 24px; text-align: center; border-right: 1px solid rgba(255,255,255,0.1);">
        <div style="font-size: 36px; font-weight: 800; color: #1d9e75; line-height: 1;">60+</div>
        <div style="font-size: 13px; color: rgba(255,255,255,0.7); margin-top: 6px; font-weight: 500;">Boats In Stock</div>
      </div>
      <div style="flex: 1; min-width: 150px; padding: 28px 24px; text-align: center; border-right: 1px solid rgba(255,255,255,0.1);">
        <div style="font-size: 36px; font-weight: 800; color: #1d9e75; line-height: 1;">50</div>
        <div style="font-size: 13px; color: rgba(255,255,255,0.7); margin-top: 6px; font-weight: 500;">States Shipped To</div>
      </div>
      <div style="flex: 1; min-width: 150px; padding: 28px 24px; text-align: center; border-right: 1px solid rgba(255,255,255,0.1);">
        <div style="font-size: 36px; font-weight: 800; color: #1d9e75; line-height: 1;">24hr</div>
        <div style="font-size: 13px; color: rgba(255,255,255,0.7); margin-top: 6px; font-weight: 500;">Quote Turnaround</div>
      </div>
      <div style="flex: 1; min-width: 150px; padding: 28px 24px; text-align: center;">
        <div style="font-size: 36px; font-weight: 800; color: #1d9e75; line-height: 1;">2</div>
        <div style="font-size: 13px; color: rgba(255,255,255,0.7); margin-top: 6px; font-weight: 500;">Crystal Coast Locations</div>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Why Trusty",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Trusty Sail & Paddle?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "More than a shop - your complete Crystal Coast watersports partner"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji — no longer displayed)",
          "default": "⚡"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Rigging Expertise"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "We've rigged hundreds of kayaks for Crystal Coast anglers. Professional installation, tournament-tested setups, shipped nationwide."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Trusty",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "icon": "⚡",
            "title": "Rigging Expertise",
            "description": "We've rigged hundreds of kayaks for Crystal Coast anglers. Professional installation, tournament-tested setups, shipped nationwide."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "🎓",
            "title": "Local Knowledge",
            "description": "We fish and sail these waters daily. Get expert recommendations for Bogue Sound, Atlantic Beach, Cape Lookout, and beyond."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "🚣",
            "title": "Try Before You Buy",
            "description": "Rent the exact kayak or sailboat you're considering. Test it on the water at our waterfront location. Love it? Your rental credits toward purchase."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "icon": "✓",
            "title": "Complete Ecosystem",
            "description": "From your first rental to your custom tournament rig. Lessons, tours, sales, rigging, service - we support your entire watersports journey."
          }
        }
      ]
    }
  ]
}
{% endschema %}
