{% comment %} trusty-pathways.liquid — photo-card style, all content from schema {% endcomment %}
<section class="trusty-pathways" style="padding: 80px 20px; background: #f5f7fa;">
  <div style="max-width: 1200px; margin: 0 auto;">

    <div style="text-align: center; margin-bottom: 48px;">
      <h2 style="font-size: 38px; font-weight: 800; color: #0a3d5c; margin: 0 0 12px;">{{ section.settings.heading }}</h2>
      <p style="font-size: 17px; color: #666; max-width: 560px; margin: 0 auto;">{{ section.settings.subtitle }}</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
      {% for block in section.blocks %}
        {% assign is_primary = false %}
        {% if block.settings.style == 'primary' %}{% assign is_primary = true %}{% endif %}

        <div {{ block.shopify_attributes }}
          style="background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.08); display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s;"
          onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 32px rgba(0,0,0,0.13)'"
          onmouseout="this.style.transform='';this.style.boxShadow='0 4px 20px rgba(0,0,0,0.08)'">

          <div style="background: {% if is_primary %}#1d9e75{% else %}#0a3d5c{% endif %}; padding: 20px 24px 18px;">
            <div style="font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,0.65); margin-bottom: 6px;">{{ block.settings.label }}</div>
            <h3 style="font-size: 26px; font-weight: 800; color: white; margin: 0; line-height: 1.1;">{{ block.settings.title }}</h3>
          </div>

          <div style="padding: 22px 24px; flex: 1; display: flex; flex-direction: column;">
            <p style="font-size: 15px; color: #555; line-height: 1.65; margin: 0 0 18px;">{{ block.settings.description }}</p>

            {% if block.settings.feature_1 != blank %}
              <ul style="list-style: none; padding: 0; margin: 0 0 22px; flex: 1;">
                {% if block.settings.feature_1 != blank %}<li style="padding: 7px 0; border-bottom: 1px solid #f0f0f0; font-size: 14px; color: #444; display: flex; align-items: center; gap: 8px;"><span style="color: #1d9e75; font-weight: 700; flex-shrink: 0;">&#10003;</span> {{ block.settings.feature_1 }}</li>{% endif %}
                {% if block.settings.feature_2 != blank %}<li style="padding: 7px 0; border-bottom: 1px solid #f0f0f0; font-size: 14px; color: #444; display: flex; align-items: center; gap: 8px;"><span style="color: #1d9e75; font-weight: 700; flex-shrink: 0;">&#10003;</span> {{ block.settings.feature_2 }}</li>{% endif %}
                {% if block.settings.feature_3 != blank %}<li style="padding: 7px 0; border-bottom: 1px solid #f0f0f0; font-size: 14px; color: #444; display: flex; align-items: center; gap: 8px;"><span style="color: #1d9e75; font-weight: 700; flex-shrink: 0;">&#10003;</span> {{ block.settings.feature_3 }}</li>{% endif %}
                {% if block.settings.feature_4 != blank %}<li style="padding: 7px 0; border-bottom: 1px solid #f0f0f0; font-size: 14px; color: #444; display: flex; align-items: center; gap: 8px;"><span style="color: #1d9e75; font-weight: 700; flex-shrink: 0;">&#10003;</span> {{ block.settings.feature_4 }}</li>{% endif %}
                {% if block.settings.feature_5 != blank %}<li style="padding: 7px 0; font-size: 14px; color: #444; display: flex; align-items: center; gap: 8px;"><span style="color: #1d9e75; font-weight: 700; flex-shrink: 0;">&#10003;</span> {{ block.settings.feature_5 }}</li>{% endif %}
              </ul>
            {% endif %}

            <a href="{{ block.settings.button_link }}"
              style="display: block; text-align: center; padding: 13px 20px; border-radius: 10px; font-size: 14px; font-weight: 700; text-decoration: none; margin-top: auto; transition: opacity .15s; background: {% if is_primary %}#1d9e75{% else %}#0a3d5c{% endif %}; color: white;"
              onmouseover="this.style.opacity='.88'" onmouseout="this.style.opacity='1'">
              {{ block.settings.button_text }}
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Three Pathways",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose Your Path" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Whether you want a turnkey rig, prefer to shop in person, or want to try first - we've got you covered" }
  ],
  "blocks": [
    {
      "type": "pathway",
      "name": "Pathway Card",
      "settings": [
        { "type": "select", "id": "style", "label": "Card Style", "options": [{ "value": "primary", "label": "Primary (Green)" }, { "value": "secondary", "label": "Secondary (Blue)" }], "default": "secondary" },
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🎣" },
        { "type": "text", "id": "label", "label": "Label", "default": "For Serious Anglers" },
        { "type": "text", "id": "title", "label": "Title", "default": "Custom Rigged" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Get a tournament-ready fishing kayak professionally rigged and shipped to your door." },
        { "type": "text", "id": "feature_1", "label": "Feature 1" },
        { "type": "text", "id": "feature_2", "label": "Feature 2" },
        { "type": "text", "id": "feature_3", "label": "Feature 3" },
        { "type": "text", "id": "feature_4", "label": "Feature 4" },
        { "type": "text", "id": "feature_5", "label": "Feature 5" },
        { "type": "text", "id": "button_text", "label": "Button Text", "default": "Learn More" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Three Pathways",
      "blocks": [
        { "type": "pathway", "settings": { "style": "primary", "icon": "🎣", "label": "For Serious Anglers", "title": "Custom Rigged", "description": "Get a tournament-ready fishing kayak professionally rigged and shipped to your door. Skip the DIY frustration.", "feature_1": "Professional component selection", "feature_2": "Expert installation & wiring", "feature_3": "Fish finder setup", "feature_4": "Rigging packages from $1,499", "feature_5": "Ships nationwide", "button_text": "Browse Rigging Packages", "button_link": "/pages/custom-rigging" } },
        { "type": "pathway", "settings": { "style": "secondary", "icon": "📍", "label": "For Smart Shoppers", "title": "Visit Our Showroom", "description": "See, touch, and compare 60+ kayaks and sailboats. Get expert advice from locals who fish these waters daily.", "feature_1": "60+ models in stock", "feature_2": "Compare side-by-side", "feature_3": "Expert local guidance", "feature_4": "Take home today or add rigging", "feature_5": "Morehead City, NC", "button_text": "Plan Your Visit", "button_link": "/pages/showroom" } },
        { "type": "pathway", "settings": { "style": "secondary", "icon": "🚣", "label": "For First-Timers", "title": "Rent First, Buy Smart", "description": "Try the exact kayak you're considering on Crystal Coast waters. Rental fees credit toward your purchase.", "feature_1": "Test on actual local waters", "feature_2": "Pedal kayaks available", "feature_3": "Guided tours offered", "feature_4": "Rental credit toward purchase", "feature_5": "Waterfront location", "button_text": "Book a Rental", "button_link": "/pages/rentals" } }
      ]
    }
  ]
}
{% endschema %}
