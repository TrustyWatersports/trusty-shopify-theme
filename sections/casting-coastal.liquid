  {%- comment -%} ═══ MEMBER PHOTOS ═══ {%- endcomment -%}
  {%- assign photo_blocks = section.blocks | where: "type", "member_photo" -%}
  <section class="cc-photos-strip">
    <div class="cc-photos-inner">
      <div class="cc-photos-header">
        <div>
          <p class="cc-section-kicker">From the Community</p>
          <h2 class="cc-section-heading" style="font-size:clamp(1.8rem,3.5vw,2.8rem);">On the Water</h2>
        </div>
        <a href="https://www.facebook.com/groups/555764118544006" target="_blank" rel="noopener" class="cc-btn-secondary" style="align-self:center;">See More on Facebook &rarr;</a>
      </div>
      {%- if photo_blocks.size > 0 -%}
        <div class="cc-photos-grid">
          {%- for block in photo_blocks -%}
            <div class="cc-photo-item" {{ block.shopify_attributes }}>
              {%- if block.settings.photo != blank -%}
                <img
                  src="{{ block.settings.photo | image_url: width: 600 }}"
                  alt="{{ block.settings.caption | default: 'Casting Coastal member photo' }}"
                  loading="lazy"
                  width="600"
                  height="450"
                />
                {%- if block.settings.caption != blank -%}
                  <div class="cc-photo-caption">{{ block.settings.caption }}</div>
                {%- endif -%}
              {%- else -%}
                <div class="cc-photo-placeholder">
                  <svg viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                  Add photo in Customizer
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="cc-photos-grid">
          {%- for i in (1..6) -%}
            <div class="cc-photo-item">
              <div class="cc-photo-placeholder">
                <svg viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                Add member photos<br/>in Customizer
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </section>

  {%- comment -%} ═══ TOURNAMENT QUICK REFERENCE ═══ {%- endcomment -%}
  <section class="cc-know-strip">
    <div class="cc-know-inner">
      <p class="cc-section-kicker" style="text-align:center;">Tournament Quick Reference</p>
      <h2 class="cc-section-heading" style="text-align:center; font-size:clamp(1.6rem,3.5vw,2.6rem);">What Every Competitor Needs to Know</h2>
      <div class="cc-know-grid">
        <div class="cc-know-item">
          <span class="cc-know-icon">🦺</span>
          <span class="cc-know-label">PFD Rule</span>
          <span class="cc-know-value">Life jacket worn at all times on the water &mdash; no exceptions, no second chances.</span>
        </div>
        <div class="cc-know-item">
          <span class="cc-know-icon">📏</span>
          <span class="cc-know-label">Measuring Boards</span>
          <span class="cc-know-value">Solid fixed or single-fold board only. No sliding boards. 30&quot;+ recommended.</span>
        </div>
        <div class="cc-know-item">
          <span class="cc-know-icon">⏰</span>
          <span class="cc-know-label">Schedule</span>
          <span class="cc-know-value">Launch 30 min before sunrise. Lines out 2:00 PM. Weigh-in opens 12:00 PM.</span>
        </div>
        <div class="cc-know-item">
          <span class="cc-know-icon">🚣</span>
          <span class="cc-know-label">Craft Rules</span>
          <span class="cc-know-value">Kayaks and SUPs only. Trolling motors allowed. No outboards, jon boats, or row boats.</span>
        </div>
        <div class="cc-know-item">
          <span class="cc-know-icon">🐟</span>
          <span class="cc-know-label">Min. Size</span>
          <span class="cc-know-value">Fish must be 12&quot; or longer. Length rounded down to nearest &frac14;&quot;. Mouth must close.</span>
        </div>
        <div class="cc-know-item">
          <span class="cc-know-icon">🏆</span>
          <span class="cc-know-label">Points Trail</span>
          <span class="cc-know-value">6-tournament Trout Series. 5 pts just for showing. Lowest score dropped at end.</span>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ═══ FOOTER CTA ═══ {%- endcomment -%}
  <section class="cc-footer-cta">
    <div class="cc-footer-cta-inner">
      <h2>Get Rigged. Get Competitive.</h2>
      <p>Stop into the shop or browse our custom rigging packages built for tournament-level kayak fishing on Crystal Coast waters.</p>
      <div class="cc-cta-row" style="justify-content:center;">
        <a href="{{ section.settings.rigging_url }}" class="cc-btn-primary">View Rigging Packages</a>
        <a href="{{ section.settings.contact_url }}" class="cc-btn-secondary">Talk to the Team</a>
      </div>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Casting Coastal Community",
  "tag": "section",
  "class": "casting-coastal-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "sponsor_logo",
      "label": "Trusty Sail & Paddle Logo",
      "info": "Displayed in the sponsor callout card. Recommended: square PNG with transparent background."
    },
    {
      "type": "url",
      "id": "rigging_url",
      "label": "Custom Rigging Page URL"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Contact Page URL"
    }
  ],
  "blocks": [
    {
      "type": "member_photo",
      "name": "Member Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)",
          "info": "Shows on hover. E.g. 'Tournament 2 — Jacksonville'"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Casting Coastal Community"
    }
  ]
}
{% endschema %}
