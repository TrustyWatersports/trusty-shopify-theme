<!-- v5 -->
<div class="container" style="padding: 40px 20px;">
  
  <!-- Breadcrumbs -->
  <div style="margin-bottom: 30px; font-size: 14px;">
    <a href="/" style="color: var(--gray-medium); text-decoration: none;">Home</a>
    <span style="color: var(--gray-medium);"> / </span>
    {% if product.collections.first %}
      <a href="/collections/{{ product.collections.first.handle }}" style="color: var(--gray-medium); text-decoration: none;">{{ product.collections.first.title }}</a>
      <span style="color: var(--gray-medium);"> / </span>
    {% endif %}
    <span style="color: var(--text-dark);">{{ product.title }}</span>
  </div>

  <div class="product-grid" style="display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: 40px; margin-bottom: 80px;">
    
    <div style="min-width: 0;">
      <div class="product-main-img-wrap">
        {% if product.featured_image %}
          <img id="main-img" src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" class="product-main-img">
        {% else %}
          <div style="width: 100%; height: 400px; display: flex; align-items: center; justify-content: center; color: var(--gray-medium);">No image available</div>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="product-thumbnails">
          {% for image in product.images %}
            <div class="product-thumb{% if forloop.first %} active{% endif %}"
                 onclick="selectThumb(this, '{{ image | image_url: width: 800 }}')">
              <img src="{{ image | image_url: width: 160 }}" alt="{{ product.title }} image {{ forloop.index }}" loading="lazy">
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div style="min-width: 0;">
      {% if product.vendor %}
        <div style="color: var(--ocean-medium); font-size: 14px; font-weight: 600; text-transform: uppercase; margin-bottom: 10px;">{{ product.vendor }}</div>
      {% endif %}
      <h1 style="font-size: 36px; color: var(--ocean-deep); margin-bottom: 20px; line-height: 1.2;">{{ product.title }}</h1>

      <div style="margin-bottom: 30px;">
        <span id="product-price" style="font-size: 42px; font-weight: 700; color: var(--text-dark);">{{ product.selected_or_first_available_variant.price | money }}</span>
      </div>

      {% if product.available %}
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 25px; color: var(--rigging-accent); font-weight: 600;">
          <span>&#10003;</span><span>In Stock - Ready to Ship or Rig</span>
        </div>
      {% else %}
        <div style="margin-bottom: 25px; color: var(--sunrise); font-weight: 600;">Out of Stock - Contact Us for ETA</div>
      {% endif %}

      <div style="font-size: 16px; line-height: 1.8; color: var(--gray-medium); margin-bottom: 30px; padding-bottom: 30px; border-bottom: 1px solid var(--gray-light);">
        {{ product.description | strip_html | truncate: 250 }}
      </div>

      {% form 'product', product %}
        {% if product.variants.size > 1 %}
          <div style="margin-bottom: 25px;">
            <label style="display: block; font-weight: 600; margin-bottom: 10px; color: var(--text-dark);">Select Option:</label>
            <select name="id" id="product-select" onchange="updatePrice(this)" style="width: 100%; padding: 12px; border: 2px solid var(--gray-light); border-radius: 8px; font-size: 16px; background: white;">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}" data-price="{{ variant.price | money }}" {% unless variant.available %}disabled{% endunless %}>
                  {{ variant.title }} - {{ variant.price | money }}{% unless variant.available %} (Sold Out){% endunless %}
                </option>
              {% endfor %}
            </select>
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        {% endif %}

        <div style="margin-bottom: 25px;">
          <label style="display: block; font-weight: 600; margin-bottom: 10px; color: var(--text-dark);">Quantity:</label>
          <input type="number" name="quantity" value="1" min="1" style="width: 100px; padding: 12px; border: 2px solid var(--gray-light); border-radius: 8px; font-size: 16px; text-align: center;">
        </div>

        {% assign has_calendly = product.metafields.custom.calendly_url %}
        <div id="checkout-section" style="display: flex; gap: 15px; margin-bottom: 30px; flex-wrap: wrap;">
          {% if has_calendly %}
            <!-- Show Add to Cart only after Calendly booking -->
            <div id="book-first-msg" style="width: 100%; padding: 16px; background: var(--gray-light); border-radius: 8px; text-align: center; color: var(--ocean-deep); font-weight: 600; font-size: 16px;">
              📅 Select your date below, then complete payment here
            </div>
            <div id="add-to-cart-wrapper" style="display: none; width: 100%; gap: 15px; display: none;">
              <button type="submit" name="add" style="flex: 1; min-width: 200px; font-size: 18px; padding: 16px; cursor: pointer; background: var(--rigging-accent); color: white; border: none; border-radius: 8px; font-weight: 700;">
                ✓ Date Selected — Add to Cart
              </button>
              <a href="/cart" style="display: flex; align-items: center; justify-content: center; padding: 16px 24px; background: var(--ocean-deep); color: white; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 16px; white-space: nowrap;">View Cart</a>
            </div>
          {% else %}
            <button type="submit" name="add" style="flex: 1; min-width: 200px; font-size: 18px; padding: 16px; cursor: pointer; background: var(--rigging-accent); color: white; border: none; border-radius: 8px; font-weight: 700;" {% unless product.available %}disabled{% endunless %}>
              {% if product.available %}Add to Cart{% else %}Out of Stock{% endif %}
            </button>
            <a href="/cart" style="display: flex; align-items: center; justify-content: center; padding: 16px 24px; background: var(--ocean-deep); color: white; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 16px; white-space: nowrap;">View Cart</a>
          {% endif %}
        </div>
      {% endform %}

      <div style="background: linear-gradient(135deg, var(--rigging-accent) 0%, #008c59 100%); color: white; padding: 25px; border-radius: 12px; margin-bottom: 30px;">
        <h3 style="font-size: 22px; margin-bottom: 12px;">&#x1F527; Want This Custom Rigged?</h3>
        <p style="margin-bottom: 15px; opacity: 0.95; line-height: 1.6;">Turn this kayak into your perfect fishing machine. Rod holders, electronics, premium accessories, and professional installation.</p>
        <a href="/pages/start-your-build?kayak={{ product.handle }}" style="display: inline-block; background: white; color: var(--rigging-accent); font-weight: 700; padding: 12px 24px; border-radius: 6px; text-decoration: none;">Configure Your Custom Rig &rarr;</a>
      </div>

      {% assign desc_html = product.description %}
      {% if desc_html contains '<li' %}
        <div style="margin-bottom: 30px;">
          <h3 style="font-size: 20px; margin-bottom: 15px; color: var(--ocean-deep);">Key Features:</h3>
          <ul style="list-style: none; padding: 0; margin: 0;" class="product-key-features">
            {{ desc_html | split: '<li' | shift | join: '<li' | prepend: '<ul>' | append: '</ul>' | split: '<ul>' | last | split: '</ul>' | first | split: '<li>' | shift | join: '<li>' }}
          </ul>
        </div>
      {% endif %}

      <div style="display: flex; gap: 20px; flex-wrap: wrap; padding: 20px; background: var(--gray-light); border-radius: 8px; text-align: center;">
        <div style="flex: 1; min-width: 100px;"><div style="font-size: 24px; margin-bottom: 5px;">&#x1F3AF;</div><div style="font-size: 13px; font-weight: 600;">Expert Rigging</div><div style="font-size: 11px; color: var(--gray-medium);">Crystal Coast pros</div></div>
        <div style="flex: 1; min-width: 100px;"><div style="font-size: 24px; margin-bottom: 5px;">&#x1F4DE;</div><div style="font-size: 13px; font-weight: 600;">Call Before You Buy</div><div style="font-size: 11px; color: var(--gray-medium);">We'll help you choose</div></div>
        <div style="flex: 1; min-width: 100px;"><div style="font-size: 24px; margin-bottom: 5px;">&#x1F6A3;</div><div style="font-size: 13px; font-weight: 600;">Try Before You Buy</div><div style="font-size: 11px; color: var(--gray-medium);">Rent at our waterfront</div></div>
      </div>
    </div>
  </div>

  <div style="max-width: 900px; margin: 0 auto 80px;">
    <h2 style="font-size: 28px; margin-bottom: 25px; color: var(--ocean-deep);">Description</h2>
    <div style="font-size: 16px; line-height: 1.8; color: var(--text-dark);">{{ product.description }}</div>
  </div>



</div>

<style>
  /* Product image gallery */
  .product-main-img-wrap {
    background: var(--gray-light);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .product-main-img {
    width: 100%;
    height: auto;
    max-height: 500px;
    object-fit: contain;
    display: block;
    margin: 0 auto;
  }
  .product-thumbnails {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 6px;
    scrollbar-width: thin;
  }
  .product-thumbnails::-webkit-scrollbar { height: 4px; }
  .product-thumbnails::-webkit-scrollbar-thumb { background: var(--gray-medium); border-radius: 2px; }
  .product-thumb {
    flex: 0 0 72px;
    width: 72px;
    height: 72px;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s;
    background: var(--gray-light);
  }
  .product-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .product-thumb.active,
  .product-thumb:hover {
    border-color: var(--ocean-medium);
  }

  /* Collapse to single column at 900px, not just 768px */
  @media (max-width: 900px) {
    .product-grid {
      grid-template-columns: 1fr !important;
      gap: 24px !important;
    }
  }
  @media (max-width: 768px) {
    .container { padding: 16px !important; }
    .product-main-img-wrap {
      width: 100%;
      max-width: 100%;
      overflow: hidden;
    }
    .product-main-img {
      width: 100% !important;
      max-width: 100% !important;
      max-height: 300px;
      object-fit: contain;
    }
  }
  .product-key-features li {
    padding: 10px 0;
    border-bottom: 1px solid var(--gray-light);
    display: flex;
    gap: 10px;
    list-style: none;
  }
  .product-key-features li:last-child { border-bottom: none; }
  .product-key-features li::before {
    content: '✓';
    color: var(--rigging-accent);
    font-weight: 700;
    flex-shrink: 0;
  }
</style>
<script>
  function selectThumb(el, src) {
    document.getElementById('main-img').src = src;
    document.querySelectorAll('.product-thumb').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
  }

  function updatePrice(select) {
    var price = select.options[select.selectedIndex].getAttribute('data-price');
    if (price) document.getElementById('product-price').textContent = price;
  }

  // Show Add to Cart after Calendly booking is complete
  function showCheckout() {
    var bookMsg = document.getElementById('book-first-msg');
    var cartWrapper = document.getElementById('add-to-cart-wrapper');
    if (bookMsg) bookMsg.style.display = 'none';
    if (cartWrapper) {
      cartWrapper.style.display = 'flex';
      cartWrapper.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  // Check if redirected back from Calendly with ?booked=true
  if (window.location.search.indexOf('booked=true') !== -1) {
    showCheckout();
  }

  // Listen for Calendly event completion
  window.addEventListener('message', function(e) {
    if (e.data.event && e.data.event === 'calendly.event_scheduled') {
      showCheckout();
    }
  });
</script>
