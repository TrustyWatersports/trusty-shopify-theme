<section style="position: relative; padding: 80px 20px; text-align: center; color: white; overflow: hidden;">
  {% if section.settings.hero_image %}
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-image: url('{{ section.settings.hero_image | img_url: '2048x' }}'); background-size: cover; background-position: center; opacity: {{ section.settings.image_opacity | divided_by: 100.0 }}; z-index: 0;"></div>
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, {{ section.settings.gradient_start }} 0%, {{ section.settings.gradient_end }} 100%); opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; z-index: 1;"></div>
  {% else %}
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, {{ section.settings.gradient_start }} 0%, {{ section.settings.gradient_end }} 100%); z-index: 0;"></div>
  {% endif %}
  <div style="max-width: 900px; margin: 0 auto; position: relative; z-index: 2;">
    <h1 style="font-size: 48px; font-weight: 800; margin-bottom: 20px;">{{ section.settings.heading }}</h1>
    <p style="font-size: 20px; opacity: 0.95; max-width: 700px; margin: 0 auto;">{{ section.settings.subheading }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Rentals Hero",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Kayak Rentals & Guided Tours" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Experience Crystal Coast waters from our waterfront location. Try before you buy - rental fees credit toward purchase!" },
    { "type": "image_picker", "id": "hero_image", "label": "Background Photo (optional)" },
    { "type": "range", "id": "image_opacity", "label": "Photo Visibility", "info": "Higher = more photo visible", "min": 0, "max": 100, "step": 5, "default": 70, "unit": "%" },
    { "type": "range", "id": "overlay_opacity", "label": "Color Overlay Strength", "min": 0, "max": 100, "step": 5, "default": 55, "unit": "%" },
    { "type": "color", "id": "gradient_start", "label": "Gradient start", "default": "#0A4B78" },
    { "type": "color", "id": "gradient_end", "label": "Gradient end", "default": "#1E6FA8" }
  ],
  "presets": [{ "name": "Rentals Hero" }]
}
{% endschema %}
