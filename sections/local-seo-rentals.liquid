{% comment %} local-seo-rentals.liquid — Rich local content for tourist/activity searches {% endcomment %}
<section style="padding: 72px 20px; background: #faf9f7;">
  <div style="max-width: 960px; margin: 0 auto;">

    <div style="text-align: center; margin-bottom: 48px;">
      <div style="display:inline-block; background:#e8f5f0; color:#0f6e56; padding:6px 16px; border-radius:20px; font-size:12px; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:14px;">On the Crystal Coast</div>
      <h2 style="font-size:32px; font-weight:800; color:#0a3d5c; margin:0 0 14px; line-height:1.15;">{{ section.settings.heading }}</h2>
      <p style="font-size:17px; color:#555; max-width:680px; margin:0 auto; line-height:1.7;">{{ section.settings.intro }}</p>
    </div>

    <!-- Activity grid -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:20px; margin-bottom:48px;">

      {% for block in section.blocks %}
        <div {{ block.shopify_attributes }} style="background:white; border-radius:14px; padding:24px; border:1px solid #e0e4de; box-shadow:0 2px 12px rgba(0,0,0,0.05);">
          <div style="width:36px; height:4px; border-radius:2px; background:#1d9e75; margin-bottom:14px;"></div>
          <h3 style="font-size:17px; font-weight:700; color:#0a3d5c; margin:0 0 8px;">{{ block.settings.title }}</h3>
          <p style="font-size:14px; color:#666; line-height:1.65; margin:0 0 14px;">{{ block.settings.description }}</p>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" style="font-size:13px; font-weight:700; color:#1d9e75; text-decoration:none;">{{ block.settings.link_text }} →</a>
          {% endif %}
        </div>
      {% endfor %}

    </div>

    <!-- Location callout -->
    <div style="background:#0a3d5c; border-radius:16px; padding:32px 36px; display:flex; align-items:center; justify-content:space-between; gap:24px; flex-wrap:wrap;">
      <div>
        <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:rgba(255,255,255,0.55); margin-bottom:6px;">Our Waterfront Location</div>
        <div style="font-size:20px; font-weight:800; color:white; margin-bottom:4px;">815 Shepard Street, Morehead City NC</div>
        <div style="font-size:14px; color:rgba(255,255,255,0.7);">{{ section.settings.hours }} &nbsp;·&nbsp; Bogue Sound waterfront launch</div>
      </div>
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a href="tel:252-515-4866" style="display:inline-block; background:#1d9e75; color:white; padding:12px 22px; border-radius:10px; font-weight:700; text-decoration:none; font-size:14px; white-space:nowrap;">📞 (252) 515-4866</a>
        <a href="{{ section.settings.book_link }}" style="display:inline-block; background:white; color:#0a3d5c; padding:12px 22px; border-radius:10px; font-weight:700; text-decoration:none; font-size:14px; white-space:nowrap;">Book Online</a>
      </div>
    </div>

    <!-- SEO-rich local text — hidden visually but readable by Google -->
    {% if section.settings.seo_text != blank %}
      <div style="margin-top:40px; padding-top:32px; border-top:1px solid #e8e4de;">
        <div style="font-size:15px; color:#666; line-height:1.8; max-width:800px; margin:0 auto; text-align:center;">
          {{ section.settings.seo_text }}
        </div>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Local SEO — Rentals",
  "settings": [
    { "type": "text",     "id": "heading",   "label": "Heading",    "default": "Things to Do on the Crystal Coast" },
    { "type": "textarea", "id": "intro",     "label": "Intro text", "default": "Trusty Sail & Paddle sits right on the Bogue Sound waterfront in downtown Morehead City, NC. Whether you're a local looking for a weekend adventure or a visitor exploring the Crystal Coast, we've got the perfect water activity for you." },
    { "type": "text",     "id": "hours",     "label": "Hours",      "default": "Open daily 9am–6pm (seasonal)" },
    { "type": "url",      "id": "book_link", "label": "Book now URL" },
    { "type": "textarea", "id": "seo_text",  "label": "SEO paragraph (shown below section)", "info": "Write naturally about your location, nearby landmarks, and activities. Google indexes this for local search.", "default": "Located at 815 Shepard Street on Bogue Sound, Trusty Sail & Paddle is one of Morehead City's top waterfront activities. Paddle to Sugarloaf Island, explore the Newport River, or cruise the Morehead City waterfront by pedal kayak. We're minutes from Atlantic Beach, Beaufort, and Fort Macon State Park — the perfect base for a Crystal Coast water adventure." }
  ],
  "blocks": [
    {
      "type": "activity",
      "name": "Activity",
      "settings": [
        { "type": "text",     "id": "title",       "label": "Title",       "default": "Kayak Rentals" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Explore Bogue Sound, paddle to Sugarloaf Island, or cruise the Morehead City waterfront." },
        { "type": "text",     "id": "link_text",   "label": "Link text",   "default": "See rentals" },
        { "type": "url",      "id": "link",         "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Local SEO — Rentals",
      "blocks": [
        { "type": "activity", "settings": { "title": "Kayak Rentals — Morehead City", "description": "Single kayaks, tandems, and pedal kayaks launching from our Bogue Sound waterfront dock. Paddle to Sugarloaf Island or explore the Newport River.", "link_text": "See pricing", "link": "/pages/rentals#kayak-rentals" } },
        { "type": "activity", "settings": { "title": "Sailboat Rentals & Lessons", "description": "Rent a Topaz dinghy or catamaran and sail Bogue Sound. Add a certified instructor for $100/hr — perfect for beginners and families.", "link_text": "See sailboats", "link": "/pages/rentals#sailboat-rentals" } },
        { "type": "activity", "settings": { "title": "Pedal Kayak Adventures", "description": "No paddling required — hands-free pedal kayaks are perfect for fishing, photography, or just relaxing on the water. Great for all ages.", "link_text": "Book hourly", "link": "/pages/rentals" } },
        { "type": "activity", "settings": { "title": "Try Before You Buy", "description": "Rent the exact kayak or sailboat you're considering. Your rental fee credits toward your purchase — test it on Crystal Coast waters first.", "link_text": "Learn more", "link": "/pages/rentals" } },
        { "type": "activity", "settings": { "title": "Guided Tours & Programs", "description": "Join one of our guided tours of Bogue Sound, kayak fishing excursions, or sailing programs for families and youth.", "link_text": "See programs", "link": "/pages/programs" } },
        { "type": "activity", "settings": { "title": "Perfect for Families & Groups", "description": "From toddlers to grandparents — our waterfront location on Shepard Street has something for everyone on the Crystal Coast.", "link_text": "Contact us", "link": "/pages/customer-info" } }
      ]
    }
  ]
}
{% endschema %}
