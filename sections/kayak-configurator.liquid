{% comment %} Kayak Rig Configurator — collection-driven, 8 accessory categories {% endcomment %}

{% assign kayak_collection     = collections[section.settings.kayak_collection] %}
{% assign rod_collection       = collections[section.settings.rod_collection] %}
{% assign fishfinder_collection= collections[section.settings.fishfinder_collection] %}
{% assign motor_collection     = collections[section.settings.motor_collection] %}
{% assign storage_collection   = collections[section.settings.storage_collection] %}
{% assign lighting_collection  = collections[section.settings.lighting_collection] %}
{% assign anchoring_collection = collections[section.settings.anchoring_collection] %}
{% assign safety_collection    = collections[section.settings.safety_collection] %}
{% assign accessories_collection = collections[section.settings.accessories_collection] %}

<section id="kayak-configurator" style="padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px; background: {{ section.settings.bg_color }};">
  <div style="max-width: 1160px; margin: 0 auto;">

    {% if section.settings.heading != blank %}
      <div style="text-align:center; margin-bottom:40px;">
        <div style="display:inline-block; background:#e8f5f0; color:#0f6e56; padding:6px 16px; border-radius:20px; font-size:12px; font-weight:700; letter-spacing:1px; margin-bottom:12px; text-transform:uppercase;">{{ section.settings.eyebrow }}</div>
        <h2 style="font-size:36px; font-weight:800; color:#0a3d5c; margin:0 0 10px;">{{ section.settings.heading }}</h2>
        <p style="font-size:17px; color:#555; max-width:600px; margin:0 auto;">{{ section.settings.subheading }}</p>
      </div>
    {% endif %}

    <div id="krc-wrap" style="display:grid; grid-template-columns:1fr 380px; gap:28px; align-items:start;">

      <!-- ── Canvas Panel ── -->
      <div style="background:#f4f6f4; border-radius:16px; border:1px solid #e0e4e0; position:relative; min-height:440px; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:28px;">
        <div style="position:relative; width:100%;">

          <img id="krc-kayak-img" src="" alt="Select a kayak"
            style="width:100%; max-height:360px; object-fit:contain; display:none; position:relative; z-index:1;" />

          <div id="krc-placeholder" style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:300px;">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" style="margin-bottom:12px; opacity:0.25;">
              <ellipse cx="32" cy="38" rx="28" ry="10" fill="#888"/>
              <path d="M4 36 Q18 24 32 26 Q46 24 60 36" stroke="#888" stroke-width="3" fill="none"/>
              <ellipse cx="4" cy="37" rx="3" ry="5" fill="#666"/>
              <ellipse cx="60" cy="37" rx="3" ry="5" fill="#666"/>
            </svg>
            <div style="font-size:14px; font-weight:600; color:#bbb;">Select a kayak to begin</div>
          </div>

          <!-- Pins — positions tuned for side-profile kayak image -->
          <div id="krc-pin-rod"        class="krc-pin" style="top:20%; left:64%;"><div class="krc-pin-bubble"><img id="krc-pin-img-rod"        src="" width="48" height="48" style="border-radius:5px;object-fit:contain;display:block;" /></div><div class="krc-pin-label" id="krc-pin-lbl-rod">Rod holder</div></div>
          <div id="krc-pin-ff"         class="krc-pin" style="top:8%;  left:44%;"><div class="krc-pin-bubble"><img id="krc-pin-img-ff"         src="" width="48" height="48" style="border-radius:5px;object-fit:contain;display:block;" /></div><div class="krc-pin-label" id="krc-pin-lbl-ff">Fish finder</div></div>
          <div id="krc-pin-motor"      class="krc-pin" style="top:52%; left:7%;"> <div class="krc-pin-bubble"><img id="krc-pin-img-motor"      src="" width="48" height="48" style="border-radius:5px;object-fit:contain;display:block;" /></div><div class="krc-pin-label" id="krc-pin-lbl-motor">Motor</div></div>
          <div id="krc-pin-storage"    class="krc-pin" style="top:22%; left:50%;"><div class="krc-pin-bubble"><img id="krc-pin-img-storage"    src="" width="48" height="48" style="border-radius:5px;object-fit:contain;display:block;" /></div><div class="krc-pin-label" id="krc-pin-lbl-storage">Storage</div></div>
          <div id="krc-pin-lighting"   class="krc-pin" style="top:8%;  left:60%;"><div class="krc-pin-bubble"><img id="krc-pin-img-lighting"   src="" width="48" height="48" style="border-radius:5px;object-fit:contain;display:block;" /></div><div class="krc-pin-label" id="krc-pin-lbl-lighting">Lighting</div></div>
          <div id="krc-pin-anchoring"  class="krc-pin" style="top:52%; left:55%;"><div class="krc-pin-bubble"><img id="krc-pin-img-anchoring"  src="" width="48" height="48" style="border-radius:5px;object-fit:contain;display:block;" /></div><div class="krc-pin-label" id="krc-pin-lbl-anchoring">Anchoring</div></div>
          <div id="krc-pin-safety"     class="krc-pin" style="top:8%;  left:28%;"><div class="krc-pin-bubble"><img id="krc-pin-img-safety"     src="" width="48" height="48" style="border-radius:5px;object-fit:contain;display:block;" /></div><div class="krc-pin-label" id="krc-pin-lbl-safety">Safety</div></div>
          <div id="krc-pin-accessories"class="krc-pin" style="top:35%; left:35%;"><div class="krc-pin-bubble"><img id="krc-pin-img-accessories"src="" width="48" height="48" style="border-radius:5px;object-fit:contain;display:block;" /></div><div class="krc-pin-label" id="krc-pin-lbl-accessories">Accessory</div></div>

        </div>
        <div style="font-size:11px; color:#bbb; margin-top:14px; text-align:center;">Accessories shown at actual mounting positions</div>
      </div>

      <!-- ── Side Panel ── -->
      <div style="display:flex; flex-direction:column; gap:12px;">

        <!-- Price bar -->
        <div style="background:#0a3d5c; color:white; border-radius:14px; padding:16px 20px; display:flex; justify-content:space-between; align-items:center;">
          <div>
            <div style="font-size:11px; opacity:0.6; margin-bottom:3px;">Rig total</div>
            <div id="krc-total" style="font-size:26px; font-weight:800;">$0</div>
            <div id="krc-base-label" style="font-size:11px; opacity:0.45; margin-top:2px;">Select a kayak to start</div>
          </div>
          <div style="text-align:right;">
            <div style="font-size:11px; opacity:0.6; margin-bottom:3px;">Add-ons</div>
            <div id="krc-addons" style="font-size:20px; font-weight:700;">+$0</div>
          </div>
        </div>

        <!-- Kayak selector -->
        <div class="krc-group">
          <div class="krc-group-label">Kayak model</div>
          <select id="krc-sel-kayak" class="krc-select" onchange="krcSelectKayak(this)">
            <option value="">— Choose a kayak —</option>
            {% if kayak_collection != blank %}{% for p in kayak_collection.products limit:60 %}<option value="{{ p.id }}" data-price="{{ p.price_min | divided_by:100.0 }}" data-title="{{ p.title | escape }}" data-img="{{ p.featured_image | img_url: 'master' }}">{{ p.title }} — {{ p.price_min | money }}</option>{% endfor %}{% endif %}
          </select>
        </div>

        <!-- Accessory category macro — repeated 8 times -->
        {% assign cats = "rod|Rod Holders|Stern zone|rod_collection,ff|Fish Finders|Console zone|fishfinder_collection,motor|Motors|Bow zone|motor_collection,storage|Crates & Storage|Tankwell zone|storage_collection,lighting|Lighting|Hull zone|lighting_collection,anchoring|Anchoring|Stern zone|anchoring_collection,safety|Safety|Cockpit zone|safety_collection,accessories|Accessories|Any zone|accessories_collection" | split: "," %}

        {% for cat in cats %}
          {% assign parts   = cat | split: "|" %}
          {% assign cat_key = parts[0] %}
          {% assign cat_label = parts[1] %}
          {% assign cat_zone  = parts[2] %}
          {% assign col_key   = parts[3] %}
          {% assign col_obj   = collections[section.settings[col_key]] %}

          <div class="krc-group">
            <div class="krc-group-label">{{ cat_label }} <span class="krc-zone-pill">{{ cat_zone }}</span></div>
            <div id="krc-slots-{{ cat_key }}">
              <div class="krc-slot" data-key="{{ cat_key }}" data-index="0">
                <select class="krc-select krc-acc-select" data-key="{{ cat_key }}" onchange="krcSelectAcc('{{ cat_key }}', this)">
                  <option value="">— None —</option>
                  {% if col_obj != blank %}{% for p in col_obj.products limit:60 %}<option value="{{ p.id }}" data-price="{{ p.price_min | divided_by:100.0 }}" data-title="{{ p.title | escape }}" data-img="{{ p.featured_image | img_url: '160x160' }}">{{ p.title }} — {{ p.price_min | money }}</option>{% endfor %}{% endif %}
                </select>
                <div class="krc-preview" style="display:none;"></div>
              </div>
            </div>
            <button class="krc-add-btn" onclick="krcAddSlot('{{ cat_key }}')">+ Add another {{ cat_label | downcase | remove: 's' }}</button>
          </div>
        {% endfor %}

        <!-- CTA -->
        <a href="#" id="krc-cta" style="display:block; background:#e8451e; color:white; border-radius:14px; padding:16px; font-size:15px; font-weight:700; text-align:center; text-decoration:none; opacity:0.4; pointer-events:none; transition:opacity .2s;">
          {{ section.settings.cta_text }} →
        </a>

      </div>
    </div>
  </div>
</section>

<style>
  .krc-pin{position:absolute;z-index:10;display:flex;flex-direction:column;align-items:center;opacity:0;transform:translate(-50%,-50%) scale(0.7);transition:opacity .25s,transform .25s;pointer-events:none;}
  .krc-pin.on{opacity:1;transform:translate(-50%,-50%) scale(1);}
  .krc-pin-bubble{background:white;border-radius:10px;border:2px solid #1d9e75;padding:4px;box-shadow:0 3px 10px rgba(0,0,0,0.15);}
  .krc-pin-label{font-size:10px;color:#444;background:white;padding:2px 8px;border-radius:8px;margin-top:4px;border:1px solid #e0e0e0;white-space:nowrap;max-width:120px;overflow:hidden;text-overflow:ellipsis;text-align:center;}
  .krc-group{background:white;border:1px solid #e0e4e0;border-radius:14px;padding:12px 14px;}
  .krc-group-label{font-size:12px;font-weight:700;color:#0a3d5c;text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
  .krc-zone-pill{font-size:10px;font-weight:600;background:#e8f5f0;color:#0f6e56;padding:2px 8px;border-radius:8px;text-transform:none;letter-spacing:0;}
  .krc-select{width:100%;padding:9px 12px;border:1.5px solid #e0e4e0;border-radius:10px;font-size:13px;color:#0a3d5c;background:#fafafa;appearance:none;cursor:pointer;outline:none;transition:border-color .15s;}
  .krc-select:focus{border-color:#1d9e75;}
  .krc-slot{margin-bottom:8px;}
  .krc-slot:last-child{margin-bottom:0;}
  .krc-preview{display:flex;align-items:center;gap:10px;margin-top:8px;padding:8px 10px;background:#f4fbf8;border-radius:8px;border:1px solid #c8e8da;}
  .krc-preview img{width:38px;height:38px;object-fit:contain;border-radius:6px;background:white;border:1px solid #e0e0e0;flex-shrink:0;}
  .krc-preview-name{font-size:12px;font-weight:600;color:#0a3d5c;line-height:1.3;}
  .krc-preview-price{font-size:12px;color:#1d9e75;margin-top:2px;}
  .krc-add-btn{margin-top:8px;background:none;border:1.5px dashed #c0d8cc;color:#0f6e56;font-size:12px;font-weight:600;padding:6px 12px;border-radius:8px;cursor:pointer;width:100%;transition:background .15s,border-color .15s;}
  .krc-add-btn:hover{background:#f0fbf6;border-color:#1d9e75;}
  @media(max-width:760px){#krc-wrap{grid-template-columns:1fr!important;}}
</style>

<script>
(function(){
  var kayakPrice = 0;
  var accData = {};
  var optHTML = {};
  var KEYS = ['rod','ff','motor','storage','lighting','anchoring','safety','accessories'];

  KEYS.forEach(function(k){
    accData[k] = [];
    var s = document.querySelector('#krc-slots-' + k + ' .krc-acc-select');
    if(s) optHTML[k] = s.innerHTML;
  });

  window.krcSelectKayak = function(sel){
    var opt = sel.options[sel.selectedIndex];
    var img = document.getElementById('krc-kayak-img');
    var ph  = document.getElementById('krc-placeholder');
    var cta = document.getElementById('krc-cta');
    if(!opt.value){
      img.style.display='none'; ph.style.display='flex';
      kayakPrice=0;
      cta.style.opacity='0.4'; cta.style.pointerEvents='none';
      document.getElementById('krc-base-label').textContent='Select a kayak to start';
    } else {
      img.src=opt.dataset.img; img.style.display='block'; ph.style.display='none';
      kayakPrice=parseFloat(opt.dataset.price)||0;
      document.getElementById('krc-base-label').textContent='Base: '+opt.dataset.title;
      cta.style.opacity='1'; cta.style.pointerEvents='auto';
    }
    updatePrice(); updateCTA();
  };

  window.krcSelectAcc = function(key, sel){
    var slot  = sel.closest('.krc-slot');
    var idx   = parseInt(slot.dataset.index,10);
    var opt   = sel.options[sel.selectedIndex];
    var prev  = slot.querySelector('.krc-preview');
    if(!opt.value){
      accData[key][idx]=null;
      prev.style.display='none';
    } else {
      var price = parseFloat(opt.dataset.price)||0;
      accData[key][idx]={price:price, title:opt.dataset.title, img:opt.dataset.img};
      prev.innerHTML='<img src="'+opt.dataset.img+'" alt="'+opt.dataset.title+'" />'
        +'<div><div class="krc-preview-name">'+opt.dataset.title+'</div>'
        +'<div class="krc-preview-price">+$'+price.toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0})+'</div></div>';
      prev.style.display='flex';
    }
    updatePin(key); updatePrice(); updateCTA();
  };

  window.krcAddSlot = function(key){
    var container = document.getElementById('krc-slots-'+key);
    var idx = container.querySelectorAll('.krc-slot').length;
    var div = document.createElement('div');
    div.className='krc-slot'; div.dataset.key=key; div.dataset.index=idx;
    div.style.marginTop='8px';
    div.innerHTML='<select class="krc-select krc-acc-select" data-key="'+key+'" onchange="krcSelectAcc(\''+key+'\',this)">'+(optHTML[key]||'')+'</select>'
      +'<div class="krc-preview" style="display:none;"></div>';
    container.appendChild(div);
  };

  function updatePin(key){
    var pin   = document.getElementById('krc-pin-'+key);
    var pImg  = document.getElementById('krc-pin-img-'+key);
    var pLbl  = document.getElementById('krc-pin-lbl-'+key);
    var first = (accData[key]||[]).find(function(d){return d!=null;});
    if(first){ pImg.src=first.img; pLbl.textContent=first.title; pin.classList.add('on'); }
    else { pin.classList.remove('on'); }
  }

  function updatePrice(){
    var addons=0;
    KEYS.forEach(function(k){ (accData[k]||[]).forEach(function(d){if(d)addons+=d.price;}); });
    document.getElementById('krc-total').textContent='$'+Math.round(kayakPrice+addons).toLocaleString();
    document.getElementById('krc-addons').textContent='+$'+Math.round(addons).toLocaleString();
  }

  function updateCTA(){
    var kSel = document.getElementById('krc-sel-kayak');
    var kOpt = kSel.options[kSel.selectedIndex];
    if(!kOpt.value) return;
    var items=[];
    KEYS.forEach(function(k){ (accData[k]||[]).forEach(function(d){if(d)items.push(d.title);}); });
    var base='{{ section.settings.quote_url }}';
    var p='?kayak='+encodeURIComponent(kOpt.dataset.title);
    if(items.length) p+='&accessories='+encodeURIComponent(items.join(', '));
    document.getElementById('krc-cta').href=base+p;
  }
})();
</script>

{% schema %}
{
  "name": "Kayak Configurator",
  "settings": [
    { "type": "text",       "id": "eyebrow",               "label": "Eyebrow",                   "default": "Custom Rigging" },
    { "type": "text",       "id": "heading",               "label": "Heading",                   "default": "Build Your Perfect Rig" },
    { "type": "textarea",   "id": "subheading",            "label": "Subheading",                "default": "Pick your kayak and add accessories. We'll rig it before it ships." },
    { "type": "collection", "id": "kayak_collection",      "label": "Kayaks collection" },
    { "type": "collection", "id": "rod_collection",        "label": "Rod holders collection" },
    { "type": "collection", "id": "fishfinder_collection", "label": "Fish finders collection" },
    { "type": "collection", "id": "motor_collection",      "label": "Motors collection" },
    { "type": "collection", "id": "storage_collection",    "label": "Crates & storage collection" },
    { "type": "collection", "id": "lighting_collection",   "label": "Lighting collection" },
    { "type": "collection", "id": "anchoring_collection",  "label": "Anchoring collection" },
    { "type": "collection", "id": "safety_collection",     "label": "Safety collection" },
    { "type": "collection", "id": "accessories_collection","label": "General accessories collection" },
    { "type": "text",       "id": "cta_text",              "label": "Button text",               "default": "Get Your Custom Rigging Quote" },
    { "type": "url",        "id": "quote_url",             "label": "Quote page URL" },
    { "type": "range",      "id": "padding_top",           "label": "Padding top",               "min": 0, "max": 120, "step": 4, "default": 60 },
    { "type": "range",      "id": "padding_bottom",        "label": "Padding bottom",            "min": 0, "max": 120, "step": 4, "default": 60 },
    { "type": "color",      "id": "bg_color",              "label": "Background color",          "default": "#ffffff" }
  ],
  "presets": [{ "name": "Kayak Configurator" }]
}
{% endschema %}
