<section style="padding: 60px 20px; background: {{ section.settings.background_color }};">
  <div style="max-width: 1200px; margin: 0 auto;">

    <div style="text-align: center; margin-bottom: 40px;">
      <h2 style="font-size: 36px; font-weight: 800; color: #0A4B78; margin-bottom: 12px;">{{ section.settings.heading }}</h2>
      <p style="font-size: 18px; color: #8B9DAF;">{{ section.settings.subheading }}</p>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start;" class="fb-events-grid">

      <!-- Facebook Follow Card -->
      <div style="display: flex; flex-direction: column; gap: 20px;">
        <div style="background: #1877F2; color: white; border-radius: 12px; padding: 40px 30px; text-align: center;">
          <div style="font-size: 64px; margin-bottom: 16px;">👍</div>
          <h3 style="font-size: 24px; font-weight: 800; margin-bottom: 12px;">Follow Us on Facebook</h3>
          <p style="opacity: 0.9; line-height: 1.6; margin-bottom: 24px; font-size: 16px;">We post all our upcoming events, tours, and programs on Facebook first. Follow us so you never miss a thing!</p>
          <a href="https://www.facebook.com/{{ section.settings.facebook_page }}" target="_blank" rel="noopener"
             style="display: inline-block; background: white; color: #1877F2; padding: 14px 32px; border-radius: 8px; text-decoration: none; font-weight: 800; font-size: 16px;">
            Follow Trusty Sail &amp; Paddle
          </a>
        </div>
        <div style="background: #F5F7FA; border-radius: 12px; padding: 30px; text-align: center;">
          <div style="font-size: 40px; margin-bottom: 12px;">📲</div>
          <h3 style="font-size: 18px; font-weight: 700; color: #0A4B78; margin-bottom: 8px;">2,000+ Local Followers</h3>
          <p style="color: #666; line-height: 1.6;">Join our Crystal Coast community of paddlers, sailors, and water lovers.</p>
        </div>
      </div>

      <!-- CTA Panel -->
      <div style="display: flex; flex-direction: column; gap: 20px;">
        <div style="background: #0A4B78; color: white; border-radius: 12px; padding: 30px;">
          <div style="font-size: 36px; margin-bottom: 12px;">📅</div>
          <h3 style="font-size: 22px; font-weight: 700; margin-bottom: 10px;">Stay in the Loop</h3>
          <p style="opacity: 0.9; line-height: 1.6; margin-bottom: 20px;">Follow our Facebook page to get notified about upcoming events, programs, and special offers as soon as they're posted.</p>
          <a href="https://www.facebook.com/{{ section.settings.facebook_page }}" target="_blank" rel="noopener"
             style="display: inline-block; background: #1877F2; color: white; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 15px;">
            👍 Follow Us on Facebook
          </a>
        </div>

        <div style="background: #F5F7FA; border-radius: 12px; padding: 30px;">
          <h3 style="font-size: 20px; font-weight: 700; color: #0A4B78; margin-bottom: 10px;">Questions About Events?</h3>
          <p style="color: #8B9DAF; line-height: 1.6; margin-bottom: 20px;">Give us a call or stop by the shop — we'd love to tell you more about our programs.</p>
          <div style="display: flex; flex-direction: column; gap: 10px;">
            <a href="tel:252-499-9911" style="display: flex; align-items: center; gap: 10px; color: #0A4B78; text-decoration: none; font-weight: 600;">📞 (252) 499-9911</a>
            <a href="tel:252-515-4866" style="display: flex; align-items: center; gap: 10px; color: #0A4B78; text-decoration: none; font-weight: 600;">📞 (252) 515-4866 Waterfront</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .fb-events-grid { grid-template-columns: 1fr !important; }
  }
</style>

{% schema %}
{
  "name": "Facebook Events",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Upcoming Events" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Follow us on Facebook to stay up to date on all our events and programs" },
    { "type": "color", "id": "background_color", "label": "Background Color", "default": "#FFFFFF" },
    { "type": "text", "id": "facebook_page", "label": "Facebook Page Name", "default": "TrustySailandPaddle", "info": "Just the page name, not the full URL" },
    { "type": "text", "id": "widget_width", "label": "Widget Width (px)", "default": "500" },
    { "type": "text", "id": "widget_height", "label": "Widget Height (px)", "default": "600" }
  ],
  "presets": [{ "name": "Facebook Events" }]
}
{% endschema %}
