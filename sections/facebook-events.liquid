<section style="padding: 60px 20px; background: {{ section.settings.background_color }};">
  <div style="max-width: 1200px; margin: 0 auto;">

    <div style="text-align: center; margin-bottom: 40px;">
      <h2 style="font-size: 36px; font-weight: 800; color: #0A4B78; margin-bottom: 12px;">{{ section.settings.heading }}</h2>
      <p style="font-size: 18px; color: #8B9DAF;">{{ section.settings.subheading }}</p>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start;" class="fb-events-grid">

      <!-- Facebook Card -->
      <div style="display: flex; flex-direction: column; gap: 20px; height: 100%;">
        <div style="background: #1877F2; color: white; border-radius: 12px; padding: 40px 30px; text-align: center; flex: 1;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" style="width:56px;height:56px;margin:0 auto 16px;display:block;"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          <h3 style="font-size: 22px; font-weight: 800; margin-bottom: 10px;">Follow Us on Facebook</h3>
          <p style="opacity: 0.9; line-height: 1.6; margin-bottom: 8px; font-size: 15px;">Events, tour announcements, demo days, and community updates — posted here first.</p>
          <p style="opacity: 0.75; font-size: 13px; margin-bottom: 24px;">2,000+ local followers</p>
          <a href="https://www.facebook.com/{{ section.settings.facebook_page }}" target="_blank" rel="noopener"
             style="display: inline-block; background: white; color: #1877F2; padding: 14px 28px; border-radius: 8px; text-decoration: none; font-weight: 800; font-size: 15px; width: 100%; box-sizing: border-box;">
            👍 Follow Trusty Sail &amp; Paddle
          </a>
        </div>
        <div style="background: #F5F7FA; border-radius: 12px; padding: 24px; text-align: center;">
          <h4 style="font-size: 15px; font-weight: 700; color: #0A4B78; margin-bottom: 8px;">Questions About Events?</h4>
          <a href="tel:252-499-9911" style="display: block; color: #0A4B78; text-decoration: none; font-weight: 600; margin-bottom: 6px;">📞 (252) 499-9911</a>
          <a href="tel:252-515-4866" style="display: block; color: #0A4B78; text-decoration: none; font-weight: 600;">📞 (252) 515-4866 Waterfront</a>
        </div>
      </div>

      <!-- Instagram Card -->
      <div style="display: flex; flex-direction: column; gap: 20px; height: 100%;">
        <div style="background: linear-gradient(135deg, #833ab4, #fd1d1d, #fcb045); color: white; border-radius: 12px; padding: 40px 30px; text-align: center; flex: 1;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" style="width:56px;height:56px;margin:0 auto 16px;display:block;"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          <h3 style="font-size: 22px; font-weight: 800; margin-bottom: 10px;">Follow Us on Instagram</h3>
          <p style="opacity: 0.9; line-height: 1.6; margin-bottom: 8px; font-size: 15px;">Behind-the-scenes builds, Crystal Coast adventures, fish, sailboats, and more.</p>
          <p style="opacity: 0.75; font-size: 13px; margin-bottom: 24px;">@{{ section.settings.instagram_handle }}</p>
          <a href="https://www.instagram.com/{{ section.settings.instagram_handle }}" target="_blank" rel="noopener"
             style="display: inline-block; background: white; color: #833ab4; padding: 14px 28px; border-radius: 8px; text-decoration: none; font-weight: 800; font-size: 15px; width: 100%; box-sizing: border-box;">
            📸 Follow on Instagram
          </a>
        </div>
        <div style="background: #F5F7FA; border-radius: 12px; padding: 24px; text-align: center;">
          <h4 style="font-size: 15px; font-weight: 700; color: #0A4B78; margin-bottom: 8px;">Tag us in your adventures!</h4>
          <p style="color: #666; font-size: 14px; margin: 0;">Use <strong>#TrustySailandPaddle</strong> and we may feature your photos!</p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .fb-events-grid { grid-template-columns: 1fr !important; }
  }
</style>

{% schema %}
{
  "name": "Facebook Events",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Upcoming Events" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Follow us on Facebook to stay up to date on all our events and programs" },
    { "type": "color", "id": "background_color", "label": "Background Color", "default": "#FFFFFF" },
    { "type": "text", "id": "facebook_page", "label": "Facebook Page Name", "default": "TrustySailandPaddle", "info": "Just the page name, not the full URL" },
    { "type": "text", "id": "instagram_handle", "label": "Instagram Handle", "default": "trustysailandpaddle", "info": "Just the handle, no @ symbol" }
  ],
  "presets": [{ "name": "Facebook Events" }]
}
{% endschema %}
