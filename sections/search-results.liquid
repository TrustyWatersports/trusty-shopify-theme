<div class="search-page page-width" style="padding: 48px 20px;">

  <!-- Search Bar -->
  <div style="max-width: 640px; margin: 0 auto 40px;">
    <h1 style="font-size: 32px; color: var(--ocean-deep); margin-bottom: 20px; text-align: center;">Search Our Store</h1>
    <form action="/search" method="get" style="display: flex; gap: 10px;">
      <input type="hidden" name="type" value="product">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="Search kayaks, sailboats, accessories..."
        style="flex: 1; padding: 14px 18px; border: 2px solid var(--gray-light); border-radius: 8px; font-size: 16px; outline: none; transition: border-color 0.2s;"
        onfocus="this.style.borderColor='var(--ocean-medium)'"
        onblur="this.style.borderColor='var(--gray-light)'"
        autofocus
      >
      <button type="submit" style="padding: 14px 24px; background: var(--rigging-accent); color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: 700; cursor: pointer; white-space: nowrap;">
        Search
      </button>
    </form>
  </div>

  <!-- Results -->
  {% if search.performed %}
    {% if search.results_count == 0 %}
      <div style="text-align: center; padding: 48px 20px; color: var(--gray-medium);">
        <div style="font-size: 48px; margin-bottom: 16px;">🔍</div>
        <h2 style="font-size: 24px; margin-bottom: 12px; color: var(--ocean-deep);">No results for "{{ search.terms | escape }}"</h2>
        <p style="margin-bottom: 24px;">Try a different search term, or browse our collections below.</p>
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          <a href="/collections/kayaks" style="padding: 10px 20px; background: var(--ocean-deep); color: white; border-radius: 6px; text-decoration: none; font-weight: 600;">Kayaks</a>
          <a href="/collections/sailboats" style="padding: 10px 20px; background: var(--ocean-deep); color: white; border-radius: 6px; text-decoration: none; font-weight: 600;">Sailboats</a>
          <a href="/collections/accessories" style="padding: 10px 20px; background: var(--ocean-deep); color: white; border-radius: 6px; text-decoration: none; font-weight: 600;">Accessories</a>
          <a href="/pages/custom-rigging" style="padding: 10px 20px; background: var(--rigging-accent); color: white; border-radius: 6px; text-decoration: none; font-weight: 600;">Custom Rigging</a>
        </div>
      </div>

    {% else %}
      <p style="text-align: center; color: var(--gray-medium); margin-bottom: 32px;">
        {{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for "<strong>{{ search.terms | escape }}</strong>"
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px;">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            <a href="{{ item.url }}" style="text-decoration: none; color: inherit; border: 1px solid rgba(0,0,0,.08); border-radius: 12px; overflow: hidden; background: #fff; transition: box-shadow 0.2s; display: block;"
               onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,.1)'"
               onmouseout="this.style.boxShadow='none'">
              <div style="background: var(--gray-light); aspect-ratio: 4/3; overflow: hidden;">
                {% if item.featured_image %}
                  <img src="{{ item.featured_image | image_url: width: 400 }}" alt="{{ item.title }}" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                {% else %}
                  <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 40px;">🚣</div>
                {% endif %}
              </div>
              <div style="padding: 14px;">
                {% if item.vendor %}
                  <div style="font-size: 11px; color: var(--ocean-medium); font-weight: 600; text-transform: uppercase; margin-bottom: 4px;">{{ item.vendor }}</div>
                {% endif %}
                <h3 style="font-size: 15px; margin: 0 0 8px; color: var(--ocean-deep); line-height: 1.3;">{{ item.title }}</h3>
                <div style="font-size: 18px; font-weight: 700; color: var(--text-dark);">
                  {{ item.price | money }}
                </div>
              </div>
            </a>
          {% else %}
            <!-- Pages / Articles -->
            <a href="{{ item.url }}" style="text-decoration: none; color: inherit; border: 1px solid rgba(0,0,0,.08); border-radius: 12px; padding: 20px; background: #fff; display: block; transition: box-shadow 0.2s;"
               onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,.1)'"
               onmouseout="this.style.boxShadow='none'">
              <div style="font-size: 11px; color: var(--ocean-medium); font-weight: 600; text-transform: uppercase; margin-bottom: 8px;">{{ item.object_type }}</div>
              <h3 style="font-size: 16px; margin: 0 0 8px; color: var(--ocean-deep);">{{ item.title }}</h3>
              {% if item.excerpt or item.content %}
                <p style="font-size: 13px; color: var(--gray-medium); margin: 0; line-height: 1.5;">{{ item.excerpt | default: item.content | strip_html | truncate: 100 }}</p>
              {% endif %}
            </a>
          {% endif %}
        {% endfor %}
      </div>

      <!-- Pagination -->
      {% if paginate.pages > 1 %}
        <div style="text-align: center; margin-top: 48px;">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}

    {% endif %}
  {% endif %}

</div>

<style>
  @media (max-width: 600px) {
    .search-page { padding: 24px 16px; }
  }
</style>

{% schema %}
{
  "name": "Search Results",
  "settings": []
}
{% endschema %}
