<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ page_title }}">
<meta property="og:type" content="{% if template.name == 'product' %}product{% else %}website{% endif %}">
<meta property="og:description" content="{% if page_description != blank %}{{ page_description | escape }}{% else %}Custom kayak rigging experts and watersports outfitter on the Crystal Coast. Kayak sales, rentals, sailing lessons, and nationwide custom rigging. Morehead City, NC.{% endif %}">
<meta property="og:locale" content="en_US">

{% if template.name == 'product' %}
  <meta property="og:image" content="https:{{ product.featured_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="product:price:amount" content="{{ product.selected_or_first_available_variant.price | money_without_currency }}">
  <meta property="product:price:currency" content="USD">
{% elsif page_image %}
  <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
{% endif %}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@trustysailandpaddle">
<meta name="twitter:title" content="{{ page_title }}">
<meta name="twitter:description" content="{% if page_description != blank %}{{ page_description | escape }}{% else %}Custom kayak rigging experts on the Crystal Coast. Morehead City, NC.{% endif %}">
