      "blocks": {
        "spot_1": {
          "type": "fishing_spot",
          "settings": {
            "spot_icon": "🎣",
            "spot_name": "Bogue Sound Flats",
            "spot_type": "Flats / Estuary",
            "spot_description": "The shallow grass flats running along the southern edge of Bogue Sound are some of the most productive inshore kayak fishing in Eastern NC. Sight-cast to tailing redfish and speckled trout from spring through fall. Easy launch from multiple points along Hwy 24.",
            "target_species": "Red Drum, Speckled Trout, Flounder",
            "best_season": "April – November, peak May–June and September–October",
            "pro_tip": "Fish the first two hours of an incoming tide on the flats nearest the marsh grass edges. Reds will push up onto the grass and give themselves away with wakes and tails."
          }
        },
        "spot_2": {
          "type": "fishing_spot",
          "settings": {
            "spot_icon": "🎣",
            "spot_name": "Radio Island Marsh",
            "spot_type": "Tidal Marsh / Creek",
            "spot_description": "The marsh complex just off Radio Island at the Morehead City port entrance is a short paddle from our waterfront location on Shepard St. Winding tidal creeks hold flounder, trout, and small reds year-round. Beginner-friendly in calm conditions.",
            "target_species": "Flounder, Speckled Trout, Red Drum",
            "best_season": "Year-round, best spring and fall",
            "pro_tip": "Work the creek mouths on a falling tide. Baitfish flush out and predators stack up at the transitions between grass and open water."
          }
        },
        "spot_3": {
          "type": "fishing_spot",
          "settings": {
            "spot_icon": "🎣",
            "spot_name": "Cape Lookout Bight",
            "spot_type": "Barrier Island / Shoals",
            "spot_description": "One of the most iconic kayak fishing destinations on the East Coast. The calm, protected waters inside the bight hold massive redfish schools in the fall. Accessed by ferry from Harkers Island or by paddling from the Power Squadron Spit. For experienced paddlers only — the crossing and shoals require reading conditions carefully.",
            "target_species": "Red Drum (trophy class), Bluefish, Flounder, Spanish Mackerel",
            "best_season": "September – November for big drum; May–August for other species",
            "pro_tip": "The drum schools at the Bight in October can number in the thousands. Use cut mullet or a large swim bait near the beach wash. Get there early — word travels fast."
          }
        },
        "spot_4": {
          "type": "fishing_spot",
          "settings": {
            "spot_icon": "🎣",
            "spot_name": "ICW — Gales Creek to Spoil Islands",
            "spot_type": "Intracoastal / Spoil Islands",
            "spot_description": "The Intracoastal Waterway between Morehead City and Swansboro offers miles of protected paddling with consistent fishing. The spoil islands created by dredging hold structure that attracts sheepshead, drum, and flounder. Watch for boat traffic and always stay to the margins.",
            "target_species": "Sheepshead, Flounder, Red Drum, Speckled Trout",
            "best_season": "Year-round",
            "pro_tip": "Sheepshead absolutely love the barnacle-covered pilings and riprap along the spoil islands. Use fiddler crabs or live shrimp and fish tight to the structure."
          }
        },
        "spot_5": {
          "type": "fishing_spot",
          "settings": {
            "spot_icon": "🎣",
            "spot_name": "Core Sound — Down East",
            "spot_type": "Open Sound / Grass Flats",
            "spot_description": "The vast shallow flats of Core Sound stretching from Smyrna down toward Harkers Island are what our Pro Staff member Lee Cox calls home. Miles of undisturbed grass flats, ancient oyster rocks, and tidal creeks that rarely see pressure. Rewards anglers willing to put in the miles on a pedal drive.",
            "target_species": "Red Drum, Speckled Trout, Black Drum, Flounder",
            "best_season": "March – December, exceptional in fall",
            "pro_tip": "This is big-water kayak territory. Bring a chartplotter, check the forecast for wind direction (NE winds can make it nasty fast), and file a float plan. The fish are worth it."
          }
        },
        "water_1": {
          "type": "water_condition",
          "settings": {
            "condition_icon": "🌊",
            "condition_title": "Tidal Flow on the Crystal Coast",
            "condition_content": "Bogue Sound and Core Sound experience semidiurnal tides — two highs and two lows per day. Tidal swings are typically 2–3 feet. Most fishing action happens in the two hours before and after tide changes, especially on outgoing tides when baitfish flush from the marsh. Always check NOAA tide tables for Beaufort Inlet before launching."
          }
        },
        "water_2": {
          "type": "water_condition",
          "settings": {
            "condition_icon": "💨",
            "condition_title": "Wind — The Variable That Rules Everything",
            "condition_content": "Southwest winds in summer are your friend — they lay the sound down flat and make for ideal paddling. Northeast winds above 10 knots can make Bogue Sound and Core Sound choppy and dangerous for kayaks. Always check the forecast before heading to open water. Our rule: if small craft advisories are posted, stay in the creeks and marsh."
          }
        },
        "water_3": {
          "type": "water_condition",
          "settings": {
            "condition_icon": "🌡️",
            "condition_title": "Water Temperature & the Bite",
            "condition_content": "Speckled trout bite best when water temps are between 60–72°F — typically spring and fall. Red drum are more temperature-tolerant but become sluggish below 50°F. In the heat of summer (80°F+), fish early morning or evening and target deeper creek channels where water stays cooler. Winter brings black drum into the sound in good numbers."
          }
        },
        "water_4": {
          "type": "water_condition",
          "settings": {
            "condition_icon": "⚡",
            "condition_title": "Afternoon Thunderstorms — Summer Hazard",
            "condition_content": "From June through September, convective thunderstorms can build rapidly over the Carolina coast in the afternoon. On open water in a kayak, lightning is an extreme hazard. Plan your trips to be off the water or back in the marsh by 2pm. Morning paddles during summer are almost always safer and the fishing is better anyway."
          }
        },
        "water_5": {
          "type": "water_condition",
          "settings": {
            "condition_icon": "🌀",
            "condition_title": "Hurricane Season Awareness",
            "condition_content": "June through November is Atlantic hurricane season, with peak activity in August and September. Even tropical storms well offshore can generate significant swell and surge into the sounds. Monitor the NHC forecast and be aware that conditions can deteriorate rapidly. The Crystal Coast takes a direct hit more often than people realize."
          }
        },
        "gear_1": {
          "type": "gear_rec",
          "settings": {
            "gear_icon": "🚣",
            "gear_name": "Kayak Drive Systems",
            "gear_reason": "Bogue Sound and Core Sound have significant fetch — you can cover a lot of water in a day. Pedal drives let you move efficiently against wind and current while keeping your hands free to cast, rig, or work a bait. On the Crystal Coast, a pedal kayak isn't a luxury, it's a serious tactical advantage.",
            "gear_recommendation": "Old Town Autopilot 136, Native Slayer Propel, NuCanoe Unlimited 14.5",
            "gear_link": "/collections/fishing-kayaks"
          }
        },
        "gear_2": {
          "type": "gear_rec",
          "settings": {
            "gear_icon": "🎯",
            "gear_name": "Rod Holders & Rigging",
            "gear_reason": "These waters demand versatility. You might be casting topwater at reds on the flats at 7am and drifting cut bait for flounder by 10am. Having multiple rod holders positioned correctly — and a layout that lets you switch rigs without chaos — is the difference between a good day and a frustrating one.",
            "gear_recommendation": "YakAttack GearTrac + LockNLoad, Scotty flush mounts for secondary rods",
            "gear_link": "/collections/fishing-accessories"
          }
        },
        "gear_3": {
          "type": "gear_rec",
          "settings": {
            "gear_icon": "🧭",
            "gear_name": "Navigation & Safety",
            "gear_reason": "Core Sound and the Cape Lookout area especially can be disorienting in fog or if conditions change fast. A chartplotter or GPS is not optional for open-water fishing here. Combine with a VHF radio, a good PFD, and a whistle — Beaufort Inlet sees commercial and recreational boat traffic year-round.",
            "gear_recommendation": "Garmin STRIKER or Echomap for fishfinder/GPS combo; Astral PFD for all-day comfort",
            "gear_link": "/collections/safety-gear"
          }
        },
        "gear_4": {
          "type": "gear_rec",
          "settings": {
            "gear_icon": "🦺",
            "gear_name": "Sun & Heat Protection",
            "gear_reason": "The Crystal Coast sun off flat water is brutal from May through October. You're on reflective water all day with no shade. Sunburn, heat exhaustion, and dehydration are real risks on a full-day paddle. Treat sun protection as seriously as you treat your tackle.",
            "gear_recommendation": "Buff face shield, UPF 50 long sleeves, wide brim hat, and bring at least 3L of water per person",
            "gear_link": ""
          }
        },
        "gear_5": {
          "type": "gear_rec",
          "settings": {
            "gear_icon": "🔧",
            "gear_name": "Custom Kayak Rigging",
            "gear_reason": "An off-the-shelf kayak can fish these waters. A properly rigged kayak will outperform it every single time. Transducer placement, power systems, anchor trolleys, crate setups, lights for pre-dawn launches — every detail matters when you're spending 8 hours on Bogue Sound chasing drum.",
            "gear_recommendation": "Our Custom Rigging packages start at $1,499 and are built specifically for how you fish Crystal Coast waters.",
            "gear_link": "/pages/custom-rigging"
          }
        }
      },
